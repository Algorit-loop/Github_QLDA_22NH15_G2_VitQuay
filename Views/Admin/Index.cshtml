@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <h2 class="mb-4"><i class="fas fa-tachometer-alt"></i> Dashboard</h2>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tổng người dùng</h6>
                            <h2 class="mb-0">@ViewBag.TotalUsers</h2>
                        </div>
                        <i class="fas fa-users fa-2x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-primary border-0">
                    <a asp-action="Users" class="text-white text-decoration-none small">
                        Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tổng khóa học</h6>
                            <h2 class="mb-0">@ViewBag.TotalCourses</h2>
                        </div>
                        <i class="fas fa-book fa-2x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-success border-0">
                    <a asp-controller="Course" asp-action="Index" class="text-white text-decoration-none small">
                        Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tổng danh mục</h6>
                            <h2 class="mb-0">@ViewBag.TotalCategories</h2>
                        </div>
                        <i class="fas fa-tags fa-2x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-info border-0">
                    <a asp-action="Categories" class="text-white text-decoration-none small">
                        Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Giảng viên</h6>
                            <h2 class="mb-0">@ViewBag.TotalInstructors</h2>
                        </div>
                        <i class="fas fa-chalkboard-teacher fa-2x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-warning border-0">
                    <a asp-action="Users" class="text-white text-decoration-none small">
                        Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <h4 class="mb-4">Thao tác nhanh</h4>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-users text-primary"></i> Quản lý người dùng</h5>
                    <p class="card-text">Quản lý tài khoản người dùng, phân quyền và xem hoạt động.</p>
                    <a asp-action="Users" class="btn btn-outline-primary">
                        Truy cập <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-tags text-success"></i> Quản lý danh mục</h5>
                    <p class="card-text">Tổ chức và quản lý các danh mục khóa học.</p>
                    <a asp-action="Categories" class="btn btn-outline-success">
                        Truy cập <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-book text-info"></i> Quản lý khóa học</h5>
                    <p class="card-text">Xem, duyệt và quản lý các khóa học trên hệ thống.</p>
                    <a asp-controller="Course" asp-action="ManageCourses" class="btn btn-outline-info">
                        Truy cập <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
