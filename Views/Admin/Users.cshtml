@model List<AppEL.Models.User>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-users"></i> @ViewData["Title"]</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Chưa có người dùng nào.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-user-circle fa-2x me-2"></i>
                                    <div>
                                        <div>@user.FullName</div>
                                        <small class="text-muted">@user.Username</small>
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <select class="form-select form-select-sm role-select" 
                                        data-user-id="@user.Id"
                                        @(user.Role == UserRole.Admin ? "disabled" : "")>
                                    @foreach (UserRole role in Enum.GetValues(typeof(UserRole)))
                                    {
                                        <option value="@role" selected="@(user.Role == role)">@role</option>
                                    }
                                </select>
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <button class="btn btn-sm btn-danger" 
                                        onclick="deleteUser('@user.Id')"
                                        @(user.Role == UserRole.Admin ? "disabled" : "")>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $('.role-select').change(function() {
            const userId = $(this).data('user-id');
            const newRole = $(this).val();
            
            if (confirm('Bạn có chắc chắn muốn thay đổi vai trò của người dùng này?')) {
                $.post('/Admin/ChangeUserRole', { userId, newRole })
                    .done(function(response) {
                        if (response.success) {
                            alert('Đã cập nhật vai trò thành công!');
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    })
                    .fail(function() {
                        alert('Có lỗi xảy ra khi cập nhật vai trò.');
                    });
            }
        });

        function deleteUser(userId) {
            if (confirm('Bạn có chắc chắn muốn xóa người dùng này? Hành động này không thể hoàn tác.')) {
                $.post('/Admin/DeleteUser', { userId })
                    .done(function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    })
                    .fail(function() {
                        alert('Có lỗi xảy ra khi xóa người dùng.');
                    });
            }
        }
    </script>
}
