@model List<Enrollment>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

<div class="container py-5">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var enrollment in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <img src="@enrollment.Course.ImageUrl" class="card-img-top" alt="@enrollment.Course.Title">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@enrollment.Course.Title</h5>
                            <p class="card-text">@enrollment.Course.ShortDescription</p>
                            <div class="mt-auto">
                                <div class="progress mb-3">
                                    <div class="progress-bar" role="progressbar" style="width: @enrollment.Progress%"
                                        aria-valuenow="@enrollment.Progress" aria-valuemin="0" aria-valuemax="100">
                                        @enrollment.Progress.ToString("0.0")%
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">@enrollment.CompletedLessons.Count/@enrollment.Course.Lessons.Count bài học</small>
                                    <a asp-action="Details" asp-route-id="@enrollment.CourseId" class="btn btn-primary">
                                        Tiếp tục học
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h4 class="alert-heading">Bạn chưa đăng ký khóa học nào!</h4>
            <p>Hãy khám phá các khóa học của chúng tôi và bắt đầu hành trình học tập của bạn.</p>
            <hr>
            <a asp-action="Index" class="btn btn-primary">Xem danh sách khóa học</a>
        </div>
    }
</div>
