@model List<AppEL.Models.Course>

@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-book"></i> @ViewData["Title"]</h2>
        <a asp-controller="Course" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Tạo khóa học mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Bạn chưa có khóa học nào.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Khóa học</th>
                        <th>Danh mục</th>
                        <th>Bài học</th>
                        <th>Trạng thái</th>
                        <th>Lượt đăng ký</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "/images/course-default.jpg" : course.ImageUrl)" 
                                         alt="@course.Title" class="me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                    <div>
                                        <div class="fw-bold">@course.Title</div>
                                        <small class="text-muted">@course.CreatedAt.ToString("dd/MM/yyyy")</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-primary">@course.Category</span>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@course.Lessons.Count bài học</span>
                            </td>
                            <td>
                                @if (course.IsPublished)
                                {
                                    <span class="badge bg-success">Đã xuất bản</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Bản nháp</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@course.EnrollmentCount học viên</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@course.Id" 
                                       class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@course.Id"
                                       class="btn btn-sm btn-outline-info" title="Quản lý bài học">
                                        <i class="fas fa-tasks"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@course.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Xóa"
                                            onclick="deleteCourse('@course.Id', '@course.Title')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        function deleteCourse(courseId, courseTitle) {
            if (confirm(`Bạn có chắc chắn muốn xóa khóa học "${courseTitle}"? Hành động này không thể hoàn tác.`)) {
                $.post('/Course/Delete', { id: courseId })
                    .done(function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    })
                    .fail(function() {
                        alert('Có lỗi xảy ra khi xóa khóa học.');
                    });
            }
        }
    </script>
}
